# Smart Traffic System Configuration
# Copy this to .env and modify as needed

# Server Settings
HOST=0.0.0.0
PORT=3000
DEBUG=False
WORKERS=1

# ML Model Settings
ML_TRAINING_SAMPLES=5000
ML_HISTORY_WINDOW=10

# Traffic Simulation Settings
TRAFFIC_UPDATE_INTERVAL=1
SPAWN_RATE_RUSH_HOUR=2
SPAWN_RATE_NORMAL=3
SPAWN_RATE_NIGHT=5

# Traffic Light Timings (seconds)
YELLOW_DURATION=3
MIN_GREEN_DURATION=10
MAX_GREEN_DURATION=40

# Thresholds
CONGESTION_THRESHOLD=60
EMERGENCY_TRAFFIC_THRESHOLD=100
EMERGENCY_SINGLE_ROAD_THRESHOLD=50

# Emergency Detection
EMERGENCY_PROBABILITY=0.001
EMERGENCY_PRIORITY_DURATION=10

# Database
DB_PATH=traffic_system.db
DB_CLEANUP_DAYS=7
DB_CLEANUP_INTERVAL_HOURS=24

# RL Optimizer (Reinforcement Learning)
RL_LEARNING_RATE=0.1
RL_DISCOUNT_FACTOR=0.95
RL_EPSILON=0.1

# GA Optimizer (Genetic Algorithm)
GA_POPULATION_SIZE=20
GA_MUTATION_RATE=0.1

# Logging
LOG_LEVEL=INFO
LOG_FILE=traffic_system.log
